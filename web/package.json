{
  "name": "anonymus-web",
  "private": true,
  "version": "3.0.0",
  "description": "AnonyMus v3 web client — Vite + Solid.js + TypeScript",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "biome lint ./src",
    "format": "biome format ./src --write",
    "check": "biome check ./src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "wasm:build": "wasm-pack build ../core/rust --target web --features wasm --out-dir src/pkg"
  },
  "dependencies": {
    "idb": "^8.0.1",
    "solid-js": "^1.9.13",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.13.2",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^26.1.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-pwa": "^1.0.0",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^3.2.4"
  }
}
