<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group
        android:pivotX="56.5"
        android:pivotY="52"
        android:scaleX="1.2"
        android:scaleY="1.2">

        <!-- Mouse body — rounded teardrop shape facing right -->
        <path
            android:pathData="M38,68 C38,56 42,46 52,42 C60,39 68,42 72,48 C76,54 76,62 72,68 C68,74 58,76 50,76 C44,76 38,74 38,68 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="38"
                    android:startY="68"
                    android:endX="72"
                    android:endY="42"
                    android:type="linear">
                    <item android:offset="0.0" android:color="#F472B6" /> <!-- Rose Gold / Pink -->
                    <item android:offset="1.0" android:color="#FDBA74" /> <!-- Copper / Amber -->
                </gradient>
            </aapt:attr>
        </path>

        <!-- Left ear (the speech-bubble ear) — larger, with a notch to evoke a chat bubble -->
        <path
            android:pathData="M44,44 C44,36 48,30 54,30 C60,30 64,36 64,44 C64,48 62,50 58,50 L54,54 L52,50 C48,50 44,48 44,44 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="44"
                    android:startY="54"
                    android:endX="64"
                    android:endY="30"
                    android:type="linear">
                    <item android:offset="0.0" android:color="#F472B6" /> <!-- Rose Gold / Pink -->
                    <item android:offset="1.0" android:color="#FDBA74" /> <!-- Copper / Amber -->
                </gradient>
            </aapt:attr>
        </path>

        <!-- Right ear — simple round -->
        <path
            android:pathData="M60,38 C60,32 64,28 68,28 C72,28 76,32 76,38 C76,44 72,46 68,46 C64,46 60,44 60,38 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="60"
                    android:startY="46"
                    android:endX="76"
                    android:endY="28"
                    android:type="linear">
                    <item android:offset="0.0" android:color="#F472B6" /> <!-- Rose Gold / Pink -->
                    <item android:offset="1.0" android:color="#FED7AA" /> <!-- Light Copper -->
                </gradient>
            </aapt:attr>
        </path>

        <!-- Eye — small dot -->
        <path
            android:fillColor="#111827"
            android:pathData="M63,54 C63,52.5 64.5,51 66,51 C67.5,51 69,52.5 69,54 C69,55.5 67.5,57 66,57 C64.5,57 63,55.5 63,54 Z" />

        <!-- Nose — tiny circle at the tip -->
        <path
            android:fillColor="#F472B6"
            android:pathData="M74,58 C74,56.8 75,56 76,56 C77,56 78,56.8 78,58 C78,59.2 77,60 76,60 C75,60 74,59.2 74,58 Z" />

        <!-- Whiskers — three delicate lines -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#FED7AA"
            android:strokeWidth="1.0"
            android:pathData="M72,56 L82,53" />
        <path
            android:fillColor="#00000000"
            android:strokeColor="#FED7AA"
            android:strokeWidth="1.0"
            android:pathData="M72,58 L83,58" />
        <path
            android:fillColor="#00000000"
            android:strokeColor="#FED7AA"
            android:strokeWidth="1.0"
            android:pathData="M72,60 L82,63" />

        <!-- Tail — curving line from the back -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#FED7AA"
            android:strokeWidth="1.8"
            android:pathData="M38,66 Q28,60 30,50 Q32,42 36,40" />

    </group>

</vector>