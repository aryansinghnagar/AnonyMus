<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group
        android:pivotX="54"
        android:pivotY="54"
        android:scaleX="1.1"
        android:scaleY="1.1">

        <!-- Connection lines from Client nodes (ears) to Central Server node (head) -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#10B981"
            android:strokeWidth="3.0"
            android:strokeLineCap="round"
            android:pathData="M32,34 L54,58" />
        <path
            android:fillColor="#00000000"
            android:strokeColor="#10B981"
            android:strokeWidth="3.0"
            android:strokeLineCap="round"
            android:pathData="M76,34 L54,58" />

        <!-- Left Client (Left Ear) -->
        <path
            android:pathData="M22,34 A10,10 0 1,1 42,34 A10,10 0 1,1 22,34 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="22"
                    android:startY="44"
                    android:endX="42"
                    android:endY="24"
                    android:type="linear">
                    <item android:offset="0.0" android:color="#34D399" />
                    <item android:offset="1.0" android:color="#059669" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Right Client (Right Ear) -->
        <path
            android:pathData="M66,34 A10,10 0 1,1 86,34 A10,10 0 1,1 66,34 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="66"
                    android:startY="44"
                    android:endX="86"
                    android:endY="24"
                    android:type="linear">
                    <item android:offset="0.0" android:color="#34D399" />
                    <item android:offset="1.0" android:color="#059669" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Central Server (Central Bubble / Face) -->
        <path
            android:pathData="M34,58 A20,20 0 1,1 74,58 A20,20 0 1,1 34,58 Z M40,73 L32,80 L46,76 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="34"
                    android:startY="78"
                    android:endX="74"
                    android:endY="38"
                    android:type="linear">
                    <item android:offset="0.0" android:color="#34D399" />
                    <item android:offset="1.0" android:color="#047857" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Whisker-like voice/sound wave lines (subtle details) -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#A7F3D0"
            android:strokeWidth="1.2"
            android:strokeLineCap="round"
            android:pathData="M37,55 C33,54 30,55 26,56" />
        <path
            android:fillColor="#00000000"
            android:strokeColor="#A7F3D0"
            android:strokeWidth="1.2"
            android:strokeLineCap="round"
            android:pathData="M36,58 C32,58 29,59 25,61" />
        <path
            android:fillColor="#00000000"
            android:strokeColor="#A7F3D0"
            android:strokeWidth="1.2"
            android:strokeLineCap="round"
            android:pathData="M37,61 C33,62 30,64 26,66" />

        <path
            android:fillColor="#00000000"
            android:strokeColor="#A7F3D0"
            android:strokeWidth="1.2"
            android:strokeLineCap="round"
            android:pathData="M71,55 C75,54 78,55 82,56" />
        <path
            android:fillColor="#00000000"
            android:strokeColor="#A7F3D0"
