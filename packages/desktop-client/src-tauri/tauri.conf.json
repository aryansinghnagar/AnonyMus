{
  "productName": "AnonyMus",
  "version": "3.0.0",
  "identifier": "com.anonymus.app",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../../web",
    "beforeBuildCommand": "npm run build --prefix ../../web",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "AnonyMus Secure Messenger",
        "width": 960,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/tor"
    ]
  }
}
