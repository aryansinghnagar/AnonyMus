# Cryptographic key for Flask sessions
FLASK_SECRET_KEY=your-secure-random-key-here

# Toggle development mode (True/False)
FLASK_DEBUG=False

# Optional: Set deployed origin for CORS and security
# DEPLOYED_ORIGIN=https://yourdomain.com

# Toggle SSL/HTTPS (Set to True to run on HTTP; required when hosting as a Tor Hidden Service)
DISABLE_SSL=False

