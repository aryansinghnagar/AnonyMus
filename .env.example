# AnonyMus Production Environment Configuration

# Session and encryption secret key (32-byte hex/random string)
SECRET_KEY=e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855

# Execution environment ('production' or 'development')
ENVIRONMENT=production

# Database URL (SQLite WAL engine via aiosqlite)
DATABASE_URL=sqlite+aiosqlite:///./anonymus.db

# Tor SOCKS5 and Control Daemon configurations
TOR_SOCKS_HOST=127.0.0.1
TOR_SOCKS_PORT=9050
TOR_CONTROL_PORT=9051

# Self-Hosted Pairwise Relay domain (clearnet or onion)
RELAY_DOMAIN=relay.anonymus.chat

# Boot transport mode ('relay' or 'p2p')
ANONYMUS_MODE=p2p
